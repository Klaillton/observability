{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Correlacao entre traces distribuidos e logs. O painel de traces foi restringido por service.name para resposta mais rapida. O painel de logs usa streams do Promtail filtradas pelo caminho de arquivo do namespace brewer.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "description": "Lista traces recentes do servico brewer para investigacao de latencia e erros. Filtro por service.name reduz tempo de resposta em relacao a busca global.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "dedicatedColumns": [],
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Start time"
          }
        ]
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "limit": 10,
          "query": "{resource.service.name=\"brewer\"}",
          "queryType": "search",
          "refId": "A"
        }
      ],
      "title": "Recent Traces (Tempo)",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Logs recentes da aplicacao brewer no Loki, filtrados pelo caminho do arquivo do pod no namespace brewer.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "expr": "{job=\"kubernetes-pod-files\",filename=~\"/var/log/pods/brewer_.*\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs da Aplicacao brewer",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Quantidade de logs enviados pelo Promtail ao Loki nos ultimos 30 minutos. Se estiver em 0, o painel de logs ficara vazio.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "expr": "sum(increase(promtail_sent_entries_total[30m]))",
          "refId": "A"
        }
      ],
      "title": "Logs Ingeridos (ultimos 30m)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": [
    "observability",
    "traces",
    "logs",
    "correlation"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Traces and Logs Correlation",
  "uid": "traces-logs-correlation",
  "version": 3,
  "weekStart": ""
}
