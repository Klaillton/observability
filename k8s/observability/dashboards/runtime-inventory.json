            },
            "renameByName": {
              "namespace": "namespace",
              "pod": "pod",
              "container": "container",
              "image": "image"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
