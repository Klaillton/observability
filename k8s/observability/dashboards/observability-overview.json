    {
      "id": 9,
      "type": "logs",
      "title": "Recent Logs",
      "description": "Fluxo de logs recentes no Loki. Filtro amplo para evitar painel vazio quando o label job nao estiver presente.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service_name=~\".+\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 12
      },
      "pluginVersion": "13.0.1"
    },
    {
      "id": 10,
      "type": "table",
      "title": "Imagens em Execucao (namespace observability)",
      "description": "Mostra pod, container e imagem em runtime via kube-state-metrics.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "kube_pod_container_info{namespace=\"observability\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "uid": true
            },
            "renameByName": {
              "container": "container",
              "image": "imagem",
              "namespace": "namespace",
              "pod": "pod"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "pluginVersion": "13.0.1"
    },
    {
      "id": 11,
      "type": "table",
      "title": "Pods Prontos (UP/DOWN)",
      "description": "Status de readiness por pod no namespace observability.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "max by (namespace,pod) (kube_pod_status_ready{namespace=\"observability\",condition=\"true\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "uid": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "ready",
              "namespace": "namespace",
              "pod": "pod"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "pluginVersion": "13.0.1"
