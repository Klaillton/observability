# ============================================================================
# Variaveis de ambiente da stack local
# ============================================================================
# Este arquivo e somente um template educacional.
# Fluxo recomendado:
# 1) Copiar para .env
# 2) Definir valores reais e fortes
# 3) Nunca versionar .env com segredos reais

# Senha do usuario admin do Grafana.
# Recomendacao:
# - minimo de 16 caracteres
# - usar letras maiusculas, minusculas, numeros e simbolos
# - nao reutilizar senhas de outros ambientes
GRAFANA_ADMIN_PASSWORD=ChangeMeNow!
